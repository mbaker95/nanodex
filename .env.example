
# Preferred: local Codex login on the host (default runtime behavior)
# CODEX_AUTH_MODE=login
# NanoDex will use ~/.codex/auth.json, the host Codex keyring entry, or cached group session auth
# Optional override if your host auth file is not in ~/.codex/auth.json
# CODEX_AUTH_FILE=

# Fallback: API key auth
OPENAI_API_KEY=
# or CODEX_API_KEY=
# OPENAI_BASE_URL=
# CODEX_MODEL=gpt-5.3-codex

# Bundled channels
ASSISTANT_HAS_OWN_NUMBER=
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
DISCORD_BOT_TOKEN=
